{{!
    @template local_hvpreport/report_view

    Report view template

    Context variables required for this template:
    * activityname - Name of the activity
    * hasgroups - Whether groups exist
    * groups - Array of groups
    * groupid - Selected group ID
    * cmid - Course module ID
    * hasstudents - Whether students exist
    * students - Array of student data
    * backurl - URL to return to activity
    * str_* - Language strings

    Example context (json):
    {
        "activityname": "My H5P Activity",
        "hasgroups": true,
        "groups": [
            {"id": 1, "name": "Group 1", "selected": false},
            {"id": 2, "name": "Group 2", "selected": true}
        ],
        "groupid": 2,
        "cmid": 123,
        "hasstudents": true,
        "students": [
            {
                "fullname": "John Doe",
                "email": "john@example.com",
                "attemptcount": 3,
                "percentagetext": "85.5%",
                "scoretext": "17.1/20",
                "timestamp": "1 Dec 2024, 10:30 AM",
                "reviewurl": "https://...",
                "hasattempts": true
            }
        ],
        "backurl": "https://..."
    }
}}

{{#hasgroups}}
<div class="mb-3">
    <form method="get" action="report.php" class="form-inline">
        <input type="hidden" name="id" value="{{cmid}}" />
        <label for="group" class="mr-2"><strong>{{str_filterbygroup}}:</strong></label>
        <select name="group" id="group" class="custom-select" onchange="this.form.submit()">
            <option value="0"{{^groupid}} selected{{/groupid}}>{{str_allgroups}}</option>
            {{#groups}}
            <option value="{{id}}"{{#selected}} selected{{/selected}}>{{name}}</option>
            {{/groups}}
        </select>
        <noscript><input type="submit" value="{{str_go}}" class="btn btn-primary ml-2" /></noscript>
    </form>
</div>
{{/hasgroups}}

{{#hasstudents}}
<div class="table-responsive">
    <table class="generaltable">
        <thead>
            <tr>
                <th>{{str_fullname}}</th>
                <th>{{str_email}}</th>
                <th>{{str_attempts}}</th>
                <th>{{str_percentage}}</th>
                <th>{{str_grade}}</th>
                <th>{{str_lastmodified}}</th>
                <th>{{str_actions}}</th>
            </tr>
        </thead>
        <tbody>
            {{#students}}
            <tr>
                <td>{{fullname}}</td>
                <td>{{email}}</td>
                <td>{{attemptcount}}</td>
                <td>{{percentagetext}}</td>
                <td>{{scoretext}}</td>
                <td>{{timestamp}}</td>
                <td>
                    {{#hasattempts}}
                    <a href="{{reviewurl}}" class="btn btn-sm btn-primary" target="_blank">{{str_viewdetails}}</a>
                    {{/hasattempts}}
                    {{^hasattempts}}
                    -
                    {{/hasattempts}}
                </td>
            </tr>
            {{/students}}
        </tbody>
    </table>
</div>
{{/hasstudents}}

{{^hasstudents}}
<div class="alert alert-info">{{str_nostudents}}</div>
{{/hasstudents}}

<div class="mt-3">
    <a href="{{backurl}}" class="btn btn-secondary">{{str_back}}</a>
</div>
