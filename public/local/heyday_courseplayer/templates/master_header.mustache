{{!
    Reusable ed2go-style master player header.
    Provided by local_heyday_courseplayer.
}}

{{#showtopbar}}
<div class="heyday-ed2go-topbar" role="banner">
    <div class="heyday-ed2go-brand {{^topbarbrand}}is-empty{{/topbarbrand}}">
        {{topbarbrand}}
    </div>

    <div class="heyday-ed2go-topbar-right" aria-label="Learner tools">
        {{#showtopbareditingtools}}
        <nav class="heyday-topbar-teacher-tools" aria-label="Teacher editing shortcuts">
            <a class="heyday-topbar-teacher-tool" href="{{editcourseurl}}">Edit structure</a>
            <a class="heyday-topbar-teacher-tool" href="{{contentbankurl}}">Content bank</a>
            <a class="heyday-topbar-teacher-tool" href="{{editsettingsurl}}">Settings</a>
        </nav>
        {{/showtopbareditingtools}}
        <a class="heyday-topbar-action" href="{{searchurl}}" aria-label="Search" title="Search"><span aria-hidden="true">⌕</span></a>
        <a class="heyday-topbar-action" href="{{helpurl}}" aria-label="Help" title="Help"><span aria-hidden="true">?</span></a>
        <a class="heyday-topbar-action heyday-topbar-tour" href="{{toururl}}" aria-label="Tour" title="Tour"><span aria-hidden="true">⚑</span><span>Tour</span></a>
        <span class="heyday-topbar-user" aria-label="Current user">{{topbaruser}} ▾</span>
    </div>
</div>
{{/showtopbar}}

<div class="heyday-courseplayer-page {{pageclass}}">
    <div class="heyday-courseplayer-shell">

        <aside class="heyday-courseplayer-sidebar" aria-label="Course menu">
            {{{sidebarhtml}}}
        </aside>

        <main class="heyday-courseplayer-main" id="heyday-courseplayer-main">
            <section class="heyday-player-card" id="heyday-player-card">

                <div class="heyday-player-topbar">
                    <a class="heyday-player-icon heyday-back-link" href="{{backurl}}" aria-label="Back" title="Back">
                        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.42-1.41L7.83 13H20v-2z"/></svg>
                    </a>

                    {{#showbookmark}}
                    <button type="button" class="heyday-player-icon heyday-bookmark" data-heyday-bookmark aria-label="Bookmark this content" title="Bookmark this content" aria-pressed="false">
                        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false"><path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1zm1 2v12.55l5-2.86 5 2.86V5H7z"/></svg>
                    </button>
                    {{/showbookmark}}

                    <span class="heyday-topbar-spacer"></span>

                    {{#showprint}}
                    <div class="heyday-print-menu-wrap" data-heyday-print-menu>
                        <button type="button" class="heyday-player-icon heyday-icon-button heyday-print-button" data-heyday-print-toggle aria-label="Print or save" title="Print or save" aria-haspopup="true" aria-expanded="false">
                            <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false"><path d="M7 3h10v5H7V3zm-2 7h14a3 3 0 0 1 3 3v5h-4v3H6v-3H2v-5a3 3 0 0 1 3-3zm3-5v3h8V5H8zm8 14v-5H8v5h8zm2-3h2v-3a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v3h2v-4h12v4zm1-2a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/></svg>
                        </button>
                        <div class="heyday-print-menu" data-heyday-print-menu-list role="menu" hidden>
                            <button type="button" role="menuitem" data-heyday-print-scope="activity">{{printactivitylabel}}</button>
                            <button type="button" role="menuitem" data-heyday-print-scope="section">{{printsectionlabel}}</button>
                        </div>
                    </div>
                    {{/showprint}}

                    {{#showfullscreen}}
                    <button type="button" class="heyday-player-icon heyday-icon-button heyday-fullscreen-button" data-heyday-fullscreen aria-label="Full screen" title="Full screen">
                        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false"><path d="M5 5h6v2H7v4H5V5zm8 0h6v6h-2V7h-4V5zM5 13h2v4h4v2H5v-6zm12 0h2v6h-6v-2h4v-4z"/></svg>
                    </button>
                    {{/showfullscreen}}
                </div>

                {{#showheading}}
                <header class="heyday-player-heading">
                    <div class="heyday-course-kicker">{{coursefullname}}</div>

                    {{#sectionline}}
                    <div class="heyday-lesson-kicker">{{sectionline}}</div>
                    {{/sectionline}}

                    {{#pagetitle}}
                    <h1>{{pagetitle}}</h1>
                    {{/pagetitle}}
                </header>
                {{/showheading}}

                <div class="heyday-content-body">
