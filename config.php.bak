<?php  // Moodle configuration file

unset($CFG);
global $CFG;
$CFG = new stdClass();

$CFG->dbtype    = 'mariadb';
$CFG->dblibrary = 'native';
$CFG->dbhost    = '127.0.0.1';
$CFG->dbname    = 'moodle_db';
$CFG->dbuser    = 'moodleuser';
$CFG->dbpass    = 'HeydayMoodle@2026';
$CFG->prefix    = 'mdl_';

$CFG->dboptions = array (
    'dbpersist' => 0,
    'dbport' => '3306',
    'dbsocket' => '',
    'dbcollation' => 'utf8mb4_unicode_ci',
);

$CFG->wwwroot   = 'http://localhost/moodle';
$CFG->dataroot = 'C:/moodledata';
$CFG->admin     = 'admin';

$CFG->directorypermissions = 0777;

// Moodle 5.2 local development settings.
// Shows useful errors, but hides PHP warning/deprecated noise from admin/plugin checks.
@error_reporting(E_ALL & ~E_WARNING & ~E_DEPRECATED & ~E_STRICT);
@ini_set('display_errors', '1');
@ini_set('display_startup_errors', '1');

$CFG->debug = E_ALL & ~E_WARNING & ~E_DEPRECATED & ~E_STRICT;
$CFG->debugdisplay = 1;

$CFG->routerconfigured = true;
$CFG->themedesignermode = false;

// Moodle 5.2 local development settings.
// Shows useful errors, but hides warning/deprecated noise from admin/plugin checks.
@error_reporting(E_ALL & ~E_WARNING & ~E_DEPRECATED & ~E_STRICT);
@ini_set('display_errors', '1');
@ini_set('display_startup_errors', '1');

$CFG->debug = E_ALL & ~E_WARNING & ~E_DEPRECATED & ~E_STRICT;
$CFG->debugdisplay = 1;

$CFG->routerconfigured = true;

// Keep this false for speed unless editing Adaptable theme files.
$CFG->themedesignermode = false;

// Local development only: stop Moodle from checking online updates/plugins.
$CFG->disableupdatenotifications = true;

require_once(__DIR__ . '/lib/setup.php');

